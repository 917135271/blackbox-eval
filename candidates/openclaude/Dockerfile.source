# syntax=docker/dockerfile:1.7

FROM node:22-bookworm-slim AS build

ARG BUN_VERSION=1.3.14
WORKDIR /src

COPY package.json bun.lock .bun-version tsconfig.json ./
COPY vendor/ vendor/
RUN npm install --global "bun@${BUN_VERSION}"
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

COPY bin/ bin/
COPY scripts/ scripts/
COPY src/ src/
RUN bun run build \
    && node dist/cli.mjs --version | grep -F "0.24.0"

RUN rm -rf node_modules \
    && bun install --frozen-lockfile --production

FROM node:22-bookworm-slim

RUN apt-get -o Acquire::Retries=5 update \
    && apt-get -o Acquire::Retries=5 install -y --no-install-recommends \
      ca-certificates git python3 ripgrep sqlite3 \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /workspace \
    && chown node:node /workspace

WORKDIR /app
COPY --from=build /src/dist/ dist/
COPY --from=build /src/bin/ bin/
COPY --from=build /src/node_modules/ node_modules/
COPY --from=build /src/package.json package.json
COPY --from=build /src/vendor/ vendor/

ENV OPENCLAUDE_NODE_MAX_OLD_SPACE_SIZE_MB=1536
WORKDIR /workspace
USER node

ENTRYPOINT ["node", "/app/bin/openclaude"]

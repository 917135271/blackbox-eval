{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "deepseek/deepseek-v4-pro",
  "enabled_providers": [
    "deepseek"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:LLM_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro"
        }
      }
    }
  },
  "permission": {
    "*": "deny"
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "deepseek/deepseek-v4-pro",
  "enabled_providers": [
    "deepseek"
  ],
  "default_agent": "audit-eval",
  "agent": {
    "audit-eval": {
      "description": "Runs the fee-audit benchmark with MCP-only fact lookup and strict JSON output.",
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "prompt": "{file:./audit_eval_prompt.txt}",
      "steps": 12,
      "permission": {
        "*": "deny",
        "policy_query_*": "allow",
        "expense_query_*": "allow",
        "read": "deny",
        "task": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "external_directory": "deny"
      }
    }
  },
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:LLM_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro"
        }
      }
    }
  },
  "permission": {
    "*": "deny",
    "policy_query_*": "allow",
    "expense_query_*": "allow",
    "read": "deny",
    "task": "deny",
    "glob": "deny",
    "grep": "deny",
    "edit": "deny",
    "write": "deny",
    "bash": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny",
    "todowrite": "deny",
    "todoread": "deny",
    "external_directory": "deny"
  },
  "mcp": {
    "policy_query": {
      "type": "local",
      "enabled": true,
      "command": [
        "python",
        "D:/算法LLM/项目篇/东方证券/agent/blackbox-eval/fixtures/policy_query_mcp.py"
      ],
      "environment": {
        "EVAL_POLICY_CORPUS_DIR": "data/corpus",
        "PYTHONIOENCODING": "utf-8"
      },
      "timeout": 30000
    },
    "expense_query": {
      "type": "local",
      "enabled": true,
      "command": [
        "python",
        "D:/算法LLM/项目篇/东方证券/agent/blackbox-eval/fixtures/expense_query_mcp.py"
      ],
      "environment": {
        "EVAL_EXPENSE_DB": "data/expense.db",
        "PYTHONIOENCODING": "utf-8"
      },
      "timeout": 30000
    }
  }
}

# syntax=docker/dockerfile:1.7

FROM oven/bun:1.3.14 AS deps

ARG OPENCODE_VERSION=1.18.1
ENV OPENCODE_VERSION=${OPENCODE_VERSION}

WORKDIR /src
COPY . .

# OpenCode imports the Bash and PowerShell parser WASM files. The packages'
# native Node addon install scripts are not used by the Bun executable and are
# unreliable under constrained builders, so they are deliberately skipped.
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --ignore-scripts \
      --network-concurrency=12 --registry=https://registry.npmjs.org
RUN find node_modules -type f -name tree-sitter-bash.wasm -print -quit | grep -q . \
    && find node_modules -type f -name tree-sitter-powershell.wasm -print -quit | grep -q .

FROM deps AS binary-build

RUN bun run packages/opencode/script/build.ts \
      --single --skip-install --skip-embed-web-ui
RUN packages/opencode/dist/opencode-linux-x64/bin/opencode --version \
    | grep -Fx "${OPENCODE_VERSION}"

FROM debian:bookworm-slim AS binary-runtime

RUN apt-get -o Acquire::Retries=5 update \
    && apt-get -o Acquire::Retries=5 install -y --no-install-recommends \
      ca-certificates git python3 ripgrep sqlite3 \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 10001 agent \
    && mkdir -p /workspace \
    && chown agent:agent /workspace

COPY --from=binary-build \
  /src/packages/opencode/dist/opencode-linux-x64/bin/opencode \
  /usr/local/bin/opencode

ENV BUN_RUNTIME_TRANSPILER_CACHE_PATH=0
WORKDIR /workspace
USER agent

ENTRYPOINT ["opencode"]

# The default engineering image executes the same locked source directly with
# Bun. It avoids the extremely expensive single-binary packaging step while
# retaining the full OpenCode source, dependency lock, and runtime behavior.
FROM deps AS source-runtime

RUN apt-get -o Acquire::Retries=5 update \
    && apt-get -o Acquire::Retries=5 install -y --no-install-recommends \
      ca-certificates git python3 ripgrep sqlite3 \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 10001 agent \
    && mkdir -p /workspace \
    && chown agent:agent /workspace

WORKDIR /workspace
USER agent

ENTRYPOINT ["bun", "run", "--define", "OPENCODE_VERSION:\"1.18.1\"", "--define", "OPENCODE_CHANNEL:\"latest\"", "--conditions=browser", "/src/packages/opencode/src/index.ts"]

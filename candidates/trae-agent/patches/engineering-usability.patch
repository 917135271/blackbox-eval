+        return self.system_prompt or TRAE_AGENT_SYSTEM_PROMPT
 
     @override
     def reflect_on_result(self, tool_results: list[ToolResult]) -> str | None:
@@ -235,6 +236,13 @@ class TraeAgent(BaseAgent):
     @override
     def _is_task_completed(self, llm_response: LLMResponse) -> bool:
         """Enhanced task completion detection."""
+        for tool_call in llm_response.tool_calls or []:
+            if tool_call.name != "task_done":
+                continue
+            result = tool_call.arguments.get("result")
+            if isinstance(result, str) and result.strip() and not llm_response.content.strip():
+                llm_response.content = result.strip()
+
         if self.must_patch == "true":
             model_patch = self.get_git_diff()
             patch = self.remove_patches_to_tests(model_patch)
@@ -252,7 +260,10 @@ class TraeAgent(BaseAgent):
     async def cleanup_mcp_clients(self) -> None:
         """Clean up all MCP clients to prevent async context leaks."""
         for client in self.mcp_clients:
-            with contextlib.suppress(Exception):
+            # anyio's stdio teardown can raise asyncio.CancelledError after the
+            # subprocess has already been closed; do not let cleanup flip a
+            # completed run into a CLI failure.
+            with contextlib.suppress(Exception, asyncio.CancelledError):
                 # Use a generic server name for cleanup since we don't track which server each client is for
                 await client.cleanup("cleanup")
         self.mcp_clients.clear()

FROM oven/bun:1.3.12 AS builder

WORKDIR /src
COPY . .

# The upstream lockfile pins the same packages and integrity hashes to a mirror
# that is unreliable in the evaluation environment. Only the registry host is
# normalized; dependency versions and integrity checks remain locked.
RUN --mount=type=cache,target=/root/.bun/install/cache \
    sed -i 's#registry\.npmmirror\.com#registry.npmjs.org#g' bun.lock \
    && bun install --frozen-lockfile --ignore-scripts

# v2.8.3 references two optional bundled Skills that are absent from its source
# tag. Keep those unrelated feature flags buildable without enabling behavior.
RUN printf '%s\n' 'export function registerHunterSkill(): void {}' \
        > src/skills/bundled/hunter.ts \
    && printf '%s\n' 'export function registerRunSkillGeneratorSkill(): void {}' \
        > src/skills/bundled/runSkillGenerator.ts \
    && printf '%s\n' \
        'export const SKILL_MODEL_VARS: Record<string, string> = {}' \
        "export const SKILL_PROMPT = ''" \
        'export const SKILL_FILES: Record<string, string> = {}' \
        > src/skills/bundled/claudeApiContent.ts \
    && mkdir -p src/utils/vendor/ripgrep \
    && bun run build \
    && bun run typecheck

FROM blackbox-eval/ccb-source-nonroot:2.8.3-base

WORKDIR /app
COPY --from=builder /src/dist ./dist

ENV HOME=/home/bun
USER bun

ENTRYPOINT ["bun", "/app/dist/cli-bun.js"]

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report-draft.schema.json",
  "type": "object",
  "required": ["audit_scope", "verified_facts", "applicable_policies", "findings", "impact", "recommendations", "anomaly_ids", "record_ids", "citations", "answer", "limitations"],
  "properties": {
    "audit_scope": {"type": "object"},
    "verified_facts": {"type": "array"},
    "applicable_policies": {"type": "array"},
    "findings": {"type": "array"},
    "impact": {"type": "array"},
    "recommendations": {"type": "array"},
    "anomaly_ids": {"type": "array", "uniqueItems": true},
    "record_ids": {"type": "array", "uniqueItems": true},
    "citations": {"type": "array", "uniqueItems": true},
    "answer": {"type": "string", "minLength": 1},
    "limitations": {"type": "array"}
  }
}

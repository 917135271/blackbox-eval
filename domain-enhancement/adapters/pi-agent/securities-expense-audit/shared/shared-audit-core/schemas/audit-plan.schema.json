{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-plan.schema.json",
  "type": "object",
  "required": ["task_scope", "audit_period", "policy_questions", "data_questions", "required_fields", "evidence_requirements", "steps", "complexity", "subagent_plan", "stopping_conditions", "unresolved_items"],
  "properties": {
    "task_scope": {"type": "object"},
    "audit_period": {"type": "object"},
    "policy_questions": {"type": "array"},
    "data_questions": {"type": "array"},
    "required_fields": {"type": "array"},
    "evidence_requirements": {"type": "array"},
    "steps": {"type": "array"},
    "complexity": {
      "type": "object",
      "required": ["score", "reasons"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 6},
        "reasons": {"type": "array"}
      }
    },
    "subagent_plan": {"type": "array"},
    "stopping_conditions": {"type": "array"},
    "unresolved_items": {"type": "array"}
  }
}

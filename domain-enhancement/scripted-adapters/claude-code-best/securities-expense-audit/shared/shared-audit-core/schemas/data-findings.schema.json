{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data-findings.schema.json",
  "type": "object",
  "required": ["population_count", "candidate_count", "record_ids", "aggregates", "completed_checks", "artifact_paths", "data_quality_issues", "limitations", "unresolved_items"],
  "properties": {
    "population_count": {"type": "integer", "minimum": 0},
    "candidate_count": {"type": "integer", "minimum": 0},
    "record_ids": {"type": "array", "uniqueItems": true},
    "aggregates": {"type": "object"},
    "completed_checks": {"type": "array"},
    "artifact_paths": {"type": "array"},
    "data_quality_issues": {"type": "array"},
    "limitations": {"type": "array"},
    "unresolved_items": {"type": "array"}
  }
}

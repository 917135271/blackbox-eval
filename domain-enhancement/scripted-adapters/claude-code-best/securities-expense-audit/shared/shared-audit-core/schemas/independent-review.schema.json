{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "independent-review.schema.json",
  "type": "object",
  "required": ["decision", "challenged_findings", "supporting_evidence", "opposing_evidence", "exceptions_or_boundaries", "required_changes", "supplemental_query", "rationale", "unresolved_conflicts"],
  "properties": {
    "decision": {"enum": ["pass", "reject", "needs_more_evidence"]},
    "challenged_findings": {"type": "array"},
    "supporting_evidence": {"type": "array"},
    "opposing_evidence": {"type": "array"},
    "exceptions_or_boundaries": {"type": "array"},
    "required_changes": {"type": "array"},
    "supplemental_query": {},
    "rationale": {"type": "string"},
    "unresolved_conflicts": {"type": "array"}
  }
}

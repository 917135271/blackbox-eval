{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subagent-summary.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "key_findings", "record_ids", "citations", "unresolved_items", "artifact_paths"],
  "properties": {
    "decision": {"type": "string", "enum": ["pass", "reject", "needs_more_evidence"]},
    "key_findings": {"type": "array"},
    "record_ids": {"type": "array", "uniqueItems": true},
    "citations": {"type": "array", "uniqueItems": true},
    "unresolved_items": {"type": "array"},
    "artifact_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}

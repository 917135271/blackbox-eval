    "reasons": [
      "policy version check (2025 vs deprecated 2022) = +1",
      "multiple policies (01,03,04,05,06,07,08) = +1",
      "aggregation/grouping/joins/batch filtering across 4240 records = +1",
      "five business rules = +1",
      "thresholds/dates/exemptions/approvals = +1",
      "comprehensive audit report = +1"
    ]
  },
  "subagent_plan": {
    "data_analyst": {
      "role": "data_analyst",
      "reason_code": "MULTI_RECORD_SCOPE",
      "complexity": 6,
      "requested_token_budget": 10000,
      "task": "全面分析2025年全年4240条报销记录,覆盖五类规则: 1)重复报销:找出所有被多次使用的发票; 2)拆分报销:同一员工+同一费用类型+7天窗口聚合; 3)超标准:逐笔检查住宿(按职级+城市档位)、培训费、业务招待(单次≤5000,人均≤300); 办公/通讯不评价月度累计; 4)超预算:按部门按reimburse_date+record_id累计,找出首次超过预算1.0倍且无special_approval的记录; 5)超期报销:expense到reimburse超过60天。每次查询必须在work/sql/保存SQL。结果写入work/analysis/data_findings.json。",
      "artifact_paths": ["work/analysis/"]
    }
  },

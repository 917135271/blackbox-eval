    {"step": 3, "action": "batch_expense_analysis (data analyst subagent)", "output": "work/analysis/data_findings.json", "status": "pending"},
    {"step": 4, "action": "evidence_coverage_check", "output": "work/evidence_matrix.json", "status": "pending"},
    {"step": 5, "action": "false_positive_review", "output": "work/independent_review.json", "status": "pending"},
    {"step": 6, "action": "audit_report", "output": "work/report_draft.json", "status": "pending"},
    {"step": 7, "action": "result_validator", "output": "work/validation_report.json", "status": "pending"},
    {"step": 8, "action": "validate_and_submit", "output": "submission", "status": "pending"}
  ],
  "complexity": {

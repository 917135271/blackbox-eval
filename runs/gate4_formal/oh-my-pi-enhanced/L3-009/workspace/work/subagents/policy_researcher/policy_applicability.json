{
  "applicable_policies": [
    {
      "doc_id": "01_expense_reimbursement_2025.md",
      "title": "XX证券费用报销管理办法(2025修订版)",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证财规〔2025〕甲号",
      "relevant_clauses": [
        {
          "clause_no": "第五条",
          "text": "单笔费用报销的审批权限,不在本办法正文列示具体金额,统一按《XX证券授权管理办法》附件二执行。费用系统应按附件二自动派生审批角色。",
          "rule_mapping": [
            "split_reimbursement"
          ]
        },
        {
          "clause_no": "第七条",
          "text": "员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。",
          "rule_mapping": [
            "overdue_reimbursement"
          ]
        },
        {
          "clause_no": "第九条",
          "text": "会计年度末发生的费用,最迟可在财政年度结束后15天内补充提交,逾期按超期报销处理。",
          "rule_mapping": [
            "overdue_reimbursement"
          ]
        },
        {
          "clause_no": "第十条",
          "text": "同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。",
          "rule_mapping": [
            "duplicate_reimbursement"
          ]
        },
        {
          "clause_no": "第十一条",
          "text": "不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规避审批。",
          "rule_mapping": [
            "split_reimbursement"
          ]
        },
        {
          "clause_no": "第十二条",
          "text": "无专项审批时,报销金额不得超过对应制度标准的1.0倍。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第十三条",
          "text": "部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。",
          "rule_mapping": [
            "over_budget"
          ]
        },
        {
          "clause_no": "第十四条",
          "text": "本办法自二〇二五年一月一日起施行。原《XX证券费用报销管理办法(2022版)》同时废止。",
          "rule_mapping": [
            "applicability"
          ]
        }
      ]
    },
    {
      "doc_id": "03_authorization_management.md",
      "title": "XX证券授权管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证综规〔2025〕丙号",
      "relevant_clauses": [
        {
          "clause_no": "第二条",
          "text": "本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。",
          "rule_mapping": [
            "split_reimbursement"
          ]
        },
        {
          "clause_no": "附件二",
          "text": "AR-01: [0, 3000) → 部门经理; AR-02: [3000, 10000) → 部门经理+财务复核; AR-03: [10000, 50000) → 部门总经理; AR-04: [50000, 200000) → 分管副总; AR-05: [200000, ∞) → 总经理办公会",
          "rule_mapping": [
            "split_reimbursement"
          ]
        },
        {
          "clause_no": "第五条",
          "text": "本办法自二〇二五年一月一日起施行。",
          "rule_mapping": [
            "applicability"
          ]
        }
      ]
    },
    {
      "doc_id": "04_travel_expense.md",
      "title": "XX证券差旅费管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证行规〔2025〕丁号",
      "relevant_clauses": [
        {
          "clause_no": "第四条",
          "text": "差旅住宿费标准: 员工级(一类450/二类380/三类300), 经理级(一类650/二类550/三类450), 部门负责人级(一类850/二类700/三类600), 高管级(一类1100/二类900/三类750), 单位:元/人/晚。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第五条",
          "text": "超过住宿标准且无专项审批的,不得报销超出部分。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第六条",
          "text": "出差期间市内交通实行包干标准:一类城市每日120元,二类城市每日100元,三类城市每日80元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第七条",
          "text": "培训期间住宿不适用本办法住宿表,应按《XX证券培训费管理办法》执行。",
          "rule_mapping": [
            "over_standard"
          ]
        }
      ]
    },
    {
      "doc_id": "05_training_expense.md",
      "title": "XX证券培训费管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证人规〔2025〕戊号",
      "relevant_clauses": [
        {
          "clause_no": "第二条",
          "text": "培训课程费按人次控制,每人每期不超过3500元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第三条",
          "text": "内部培训综合费用每日不超过800元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第四条",
          "text": "外部培训综合费用每日不超过1200元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第五条",
          "text": "培训期间住宿标准: 一类城市500元, 二类城市420元, 三类城市350元, 单位:元/人/晚。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第六条",
          "text": "培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。",
          "rule_mapping": [
            "over_standard"
          ]
        }
      ]
    },
    {
      "doc_id": "06_business_entertainment.md",
      "title": "XX证券业务招待费管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证客规〔2025〕己号",
      "relevant_clauses": [
        {
          "clause_no": "第二条",
          "text": "业务招待单次活动费用不得超过5000元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第三条",
          "text": "业务招待费用按参与人数核算,人均不得超过300元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第四条",
          "text": "同一客户拜访或同一会议安排不得拆分为多个报销事项。",
          "rule_mapping": [
            "split_reimbursement"
          ]
        }
      ]
    },
    {
      "doc_id": "07_office_communication.md",
      "title": "XX证券办公与通讯费用管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证办规〔2025〕庚号",
      "relevant_clauses": [
        {
          "clause_no": "第二条",
          "text": "员工个人办公用品报销按月控制,每人每月不超过600元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第三条",
          "text": "员工通讯费用报销按月控制,每人每月不超过300元。",
          "rule_mapping": [
            "over_standard"
          ]
        },
        {
          "clause_no": "第四条",
          "text": "办公费用和通讯费用不得以其他费用类型绕开月度控制。",
          "rule_mapping": [
            "over_standard"
          ]
        }
      ]
    },
    {
      "doc_id": "08_budget_management.md",
      "title": "XX证券预算管理办法",
      "effective_date": "2025-01-01",
      "status": "active",
      "document_number": "XX证财规〔2025〕辛号",
      "relevant_clauses": [
        {
          "clause_no": "第三条",
          "text": "部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。",
          "rule_mapping": [
            "over_budget"
          ]
        },
        {
          "clause_no": "第四条",
          "text": "因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。",
          "rule_mapping": [
            "over_budget"
          ]
        }
      ]
    }

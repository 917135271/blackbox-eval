{"type":"item.completed","item":{"id":"item_14","type":"mcp_tool_call","server":"policy_query","tool":"get_policy_excerpt","arguments":{"doc_id":"08_budget_management.md","query":"专项审批 超预算 special approval process"},"result":{"content":[{"text":"{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"query\": \"专项审批 超预算 special approval process\", \"excerpts\": [\"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\", \"# XX证券预算管理办法\", \"第一条 为加强XX证券预算约束和费用过程控制,制定本办法。\", \"## 第二章 预算执行\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\"]}","type":"text"}],"structured_content":null},"error":null,"status":"completed"}}

{"type":"item.completed","item":{"id":"item_5","type":"mcp_tool_call","server":"policy_query","tool":"search_policy","arguments":{"query":"预算超支 超额 超预算","top_k":5},"result":{"content":[{"text":"{\"query\": \"预算超支 超额 超预算\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 23.5672, \"snippets\": [\"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 17.8145, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 10.1516, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"第二条 业务招待单次活动费用不得超过5000元。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 6.5112, \"snippets\": [\"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"第三条 内部培训综合费用每日不超过800元。\", \"第四条 外部培训综合费用每日不超过1200元。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 5.8269, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\"]}]}","type":"text"}],"structured_content":null},"error":null,"status":"completed"}}

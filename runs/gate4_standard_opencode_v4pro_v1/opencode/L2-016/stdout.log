{"type":"tool_use","timestamp":1783581710027,"sessionID":"ses_0ba3f13b6ffeIv4MVyyzN7d1BI","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_01_Opuerm6RoOUprQ42Ucv85233","state":{"status":"completed","input":{"query":"超预算 部门预算 超支 审批"},"output":"{\"query\": \"超预算 部门预算 超支 审批\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 21.627, \"snippets\": [\"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 17.0958, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 8.4723, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"第五条 本办法由财务部门负责解释。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 4.6033, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\", \"| 部门负责人级 | 850元 | 700元 | 600元 |\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 4.5928, \"snippets\": [\"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"第三条 内部培训综合费用每日不超过800元。\", \"第四条 外部培训综合费用每日不超过1200元。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783581709904,"end":1783581709954}},"id":"prt_f45c1163700146EZ5opCnA4GDE","sessionID":"ses_0ba3f13b6ffeIv4MVyyzN7d1BI","messageID":"msg_f45c0efca001UQZm6hg984niF6"}}

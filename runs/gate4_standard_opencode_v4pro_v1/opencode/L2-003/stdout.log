{"type":"tool_use","timestamp":1783580594956,"sessionID":"ses_0ba506b2affe9VVsb1HNxjtfYL","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_02_7ZpLwvOQVkVLX2Txw17S8235","state":{"status":"completed","input":{"query":"重复报销 发票 多次使用"},"output":"{\"query\": \"重复报销 发票 多次使用\", \"top_k\": 5, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 14.4935, \"snippets\": [\"第十条 同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 5.0438, \"snippets\": [\"第四条 同一客户拜访或同一会议安排不得拆分为多个报销事项。\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 2.4566, \"snippets\": [\"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第五条 本办法与费用报销制度共同构成费用控制依据。\", \"第二条 各部门应在年度预算额度内发生费用。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 2.0493, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\", \"发文字号: XX证人规〔2025〕戊号\"]}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\", \"score\": 2.0232, \"snippets\": [\"第二条 本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。\", \"## 附件二 费用报销审批权限表\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783580594926,"end":1783580594940}},"id":"prt_f45b01190001DZDi7FyJLRT42v","sessionID":"ses_0ba506b2affe9VVsb1HNxjtfYL","messageID":"msg_f45afde23001N7Z8D4FfZLDeCa"}}

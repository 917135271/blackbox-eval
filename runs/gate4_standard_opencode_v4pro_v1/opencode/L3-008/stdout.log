{"type":"tool_use","timestamp":1783583636086,"sessionID":"ses_0ba21ad07ffexKUMHwk8epMUTI","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_YP2dMIA7Gyfr2GlpIg8m5636","state":{"status":"completed","input":{"query":"差旅住宿标准 培训住宿标准","top_k":6},"output":"{\"query\": \"差旅住宿标准 培训住宿标准\", \"top_k\": 6, \"results\": [{\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 30.4776, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"第五条 培训期间住宿标准如下,单位为元/人/晚。\", \"| 城市档位 | 培训住宿标准 |\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 29.3248, \"snippets\": [\"第七条 培训期间住宿不适用本办法住宿表,应按《XX证券培训费管理办法》执行。\", \"第四条 差旅住宿费标准如下,单位为元/人/晚。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 6.4677, \"snippets\": [\"第二条 本办法适用于XX证券各部门、分支机构及全体员工发生的差旅、培训、招待、办公、通讯等费用报销事项。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 0.8989, \"snippets\": [\"## 第二章 标准管理\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 0.7415, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}, {\"doc_id\": \"13_procurement_management.md\", \"title\": \"XX证券采购管理办法\", \"score\": 0.7403, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783583636031,"end":1783583636066}},"id":"prt_f45de79fe001SdHfNIqb1fnQCw","sessionID":"ses_0ba21ad07ffexKUMHwk8epMUTI","messageID":"msg_f45de559a001J7CI32aqfod6Sb"}}

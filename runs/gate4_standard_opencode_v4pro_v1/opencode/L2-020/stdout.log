{"type":"tool_use","timestamp":1783582571464,"sessionID":"ses_0ba31ead2ffex30eZTATxtssqi","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_01_kf5CCVcXe6ygVwYRvPpF6648","state":{"status":"completed","input":{"query":"超预算 部门预算 控制 审批"},"output":"{\"query\": \"超预算 部门预算 控制 审批\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 22.806, \"snippets\": [\"第一条 为加强XX证券预算约束和费用过程控制,制定本办法。\", \"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\", \"第二条 各部门应在年度预算额度内发生费用。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 15.4886, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 6.5771, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"第五条 本办法由财务部门负责解释。\", \"第一条 为规范XX证券业务招待活动,坚持必要、节俭、透明原则,制定本办法。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 5.3341, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"第四条 办公费用和通讯费用不得以其他费用类型绕开月度控制。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 4.2082, \"snippets\": [\"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"第三条 内部培训综合费用每日不超过800元。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783582571410,"end":1783582571443}},"id":"prt_f45ce3b850011Ow7rWqFS2NNP1","sessionID":"ses_0ba31ead2ffex30eZTATxtssqi","messageID":"msg_f45ce175d001K0tfS9aPMvW4R8"}}

{"type":"tool_use","timestamp":1783580787460,"sessionID":"ses_0ba4d3d49ffe16Iyy4DeuszBrZ","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_01_5WmWTf9rGnAjv2fvJ9KY2367","state":{"status":"completed","input":{"query":"重复报销 同一发票 多次报销 异常"},"output":"{\"query\": \"重复报销 同一发票 多次报销 异常\", \"top_k\": 5, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 16.4894, \"snippets\": [\"第十条 同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 7.7561, \"snippets\": [\"第四条 同一客户拜访或同一会议安排不得拆分为多个报销事项。\", \"发文字号: XX证客规〔2025〕己号\", \"## 第一章 总则\"]}, {\"doc_id\": \"11_attendance_management.md\", \"title\": \"XX证券考勤与休假管理办法\", \"score\": 5.1206, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券考勤记录、请假申请、外勤登记和异常处理相关管理事项,制定本办法。\", \"发文字号: XX证综规〔2025〕备号\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 3.2584, \"snippets\": [\"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\", \"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\"]}, {\"doc_id\": \"16_contract_management.md\", \"title\": \"XX证券合同管理办法\", \"score\": 2.5802, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券合同起草、法务审核、签署和履约跟踪相关管理事项,制定本办法。\", \"# XX证券合同管理办法\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783580787395,"end":1783580787436}},"id":"prt_f45b30263001L5UwXZjUw6sa5x","sessionID":"ses_0ba4d3d49ffe16Iyy4DeuszBrZ","messageID":"msg_f45b2ee83001AWtAZw68S3N4qe"}}

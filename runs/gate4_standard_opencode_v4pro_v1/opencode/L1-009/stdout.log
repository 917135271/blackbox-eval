{"type":"tool_use","timestamp":1783579717499,"sessionID":"ses_0ba5db601ffenC2RUSQV0CqsZM","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_u3x5PPbLzEBxDnLzPPI45584","state":{"status":"completed","input":{"query":"超预算 部门年度预算 累计报销超过预算 异常","top_k":5},"output":"{\"query\": \"超预算 部门年度预算 累计报销超过预算 异常\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 36.9604, \"snippets\": [\"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 25.0354, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第九条 会计年度末发生的费用,最迟可在财政年度结束后15天内补充提交,逾期按超期报销处理。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 11.0502, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"第四条 同一客户拜访或同一会议安排不得拆分为多个报销事项。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 7.3052, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\"]}, {\"doc_id\": \"11_attendance_management.md\", \"title\": \"XX证券考勤与休假管理办法\", \"score\": 5.7713, \"snippets\": [\"第三条 牵头部门负责制度解释、流程维护和监督检查。\", \"第四条 各部门应结合岗位职责落实过程管理要求,形成完整、真实、可追溯的管理记录。\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783579717447,"end":1783579717472}},"id":"prt_f45a2af350015eMVNNgnXATtCB","sessionID":"ses_0ba5db601ffenC2RUSQV0CqsZM","messageID":"msg_f45a29ad0001YoblGNbN1Ww5MY"}}

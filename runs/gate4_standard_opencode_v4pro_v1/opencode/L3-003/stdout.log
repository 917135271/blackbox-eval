{"type":"tool_use","timestamp":1783583137027,"sessionID":"ses_0ba297157ffekHpPR9WYXLU3Oh","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_01_5gmB1jRSg7IjbnGFpYzz2842","state":{"status":"completed","input":{"query":"超标准 超标 专项 扫描"},"output":"{\"query\": \"超标准 超标 专项 扫描\", \"top_k\": 5, \"results\": [{\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 5.9986, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\", \"## 第三章 住宿标准\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 5.5721, \"snippets\": [\"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 5.3319, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"## 第二章 培训费用标准\", \"第五条 培训期间住宿标准如下,单位为元/人/晚。\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 5.1282, \"snippets\": [\"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 4.8161, \"snippets\": [\"## 第二章 标准管理\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"第三条 业务招待费用按参与人数核算,人均不得超过300元。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783583133649,"end":1783583134931}},"id":"prt_f45d6cba8001vtsH5EAZaN6nRy","sessionID":"ses_0ba297157ffekHpPR9WYXLU3Oh","messageID":"msg_f45d690c6001kNa1EwS6pT1iHC"}}

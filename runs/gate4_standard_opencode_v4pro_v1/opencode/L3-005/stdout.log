{"type":"tool_use","timestamp":1783583525461,"sessionID":"ses_0ba235e01ffetLrWZnNKDKQdam","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_S5LFOreQ6vVt8tOuSyLO1315","state":{"status":"completed","input":{"query":"报销时限 超期 报销 天数 限制","top_k":5},"output":"{\"query\": \"报销时限 超期 报销 天数 限制\", \"top_k\": 5, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 13.0677, \"snippets\": [\"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第十条 同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 5.2682, \"snippets\": [\"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\", \"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\"]}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\", \"score\": 4.2508, \"snippets\": [\"第一条 本办法为XX证券旧版费用报销制度文本,仅作为制度沿革留档。现行制度应以《XX证券费用报销管理办法(2025修订版)》为准。\", \"第二条 旧版制度曾规定,单笔报销金额达到8000元的,应提交部门总经理审批。\", \"第三条 旧版制度曾规定,单笔报销金额达到30000元的,应提交分管副总审批。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 4.2298, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\", \"第一条 为规范XX证券员工公务出差费用管理,制定本办法。\"]}, {\"doc_id\": \"14_hr_transfer.md\", \"title\": \"XX证券人员调动管理办法\", \"score\": 3.8798, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券岗位调整、任职通知、交接确认和权限变更相关管理事项,制定本办法。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783583525423,"end":1783583525440}},"id":"prt_f45dcca18001CyXIFrP1eMK4t9","sessionID":"ses_0ba235e01ffetLrWZnNKDKQdam","messageID":"msg_f45dca42b001gpNkRImwW0QAKv"}}

              "content": [
                {
                  "type": "text",
                  "text": "{\"query\": \"预算管理 超预算 部门预算 报销\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 26.8465, \"snippets\": [\"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"# XX证券预算管理办法\", \"第二条 各部门应在年度预算额度内发生费用。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 18.8064, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第三条 费用报销实行经办人真实性承诺、部门负责人业务审核、财务复核和授权审批相结合的管理原则。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 8.9966, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"# XX证券业务招待费管理办法\", \"## 第二章 标准管理\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 2.2842, \"snippets\": [\"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"# XX证券培训费管理办法\", \"第三条 内部培训综合费用每日不超过800元。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 2.2786, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"# XX证券办公与通讯费用管理办法\"]}]}"

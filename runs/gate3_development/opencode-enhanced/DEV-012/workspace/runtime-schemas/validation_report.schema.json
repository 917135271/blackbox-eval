{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation-report.schema.json",
  "type": "object",
  "required": ["status", "errors", "warnings", "field_checks", "id_checks", "evidence_checks", "answer_consistency_checks", "repair_count", "repairable_fields", "submission_allowed"],
  "properties": {
    "status": {"enum": ["pass", "fail"]},
    "errors": {"type": "array"},
    "warnings": {"type": "array"},
    "field_checks": {"type": "object"},
    "id_checks": {"type": "object"},
    "evidence_checks": {"type": "object"},
    "answer_consistency_checks": {"type": "object"},
    "repair_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "repairable_fields": {"type": "array"},
    "submission_allowed": {"type": "boolean"}
  }
}

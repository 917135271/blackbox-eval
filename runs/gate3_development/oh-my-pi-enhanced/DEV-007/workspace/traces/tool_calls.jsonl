{"arguments": {}, "error": null, "ok": true, "result_preview": {"preview": "{\"corpus_dir\": \"/benchmark/data/corpus\", \"documents\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\"}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\"}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\"}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\"}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\"}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\"}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\"}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\"}, {\"doc_id\": \"09_information_security.md\", \"title\": \"XX证券信息安全管理办法\"}, {\"doc_id\": \"10_seal_management.md\", \"title\": \"XX证券印章管理办法\"}, {\"doc_id\": \"11_attendance_management.md\", \"title\": \"XX证券考勤与休假管理办法\"}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\"}, {\"doc_id\": \"13_procurement_management.md\", \"title\": \"XX证券采购管理办法\"}, {\"doc_id\": \"14_hr_transfer.md\", \"title\": \"XX证券人员调动管理办法\"}, {\"doc_id\": \"15_meeting_management.md\", \"title\": \"XX证券会议管理办法\"}, {\"doc_id\": \"16_contract_management.md\", \"title\": \"XX证券合同管理办法\"}, {\"doc_id\": \"17_confidentiality.md\", \"title\": \"XX证券保密管理办法\"}, {\"doc_id", "truncated": true}, "server": "policy_query_mcp", "tool": "list_policy_docs", "ts": 1784200648.7497149}

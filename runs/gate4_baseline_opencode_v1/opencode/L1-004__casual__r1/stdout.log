{"type":"tool_use","timestamp":1783412033019,"sessionID":"ses_0c45c28d3ffejq1z8P2CsHC8PZ","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_a1xsGcR4qdhNschLcAf52966","state":{"status":"completed","input":{"query":"员工 一类城市 出差 住宿 每晚 上限","top_k":5},"output":"{\"query\": \"员工 一类城市 出差 住宿 每晚 上限\", \"top_k\": 5, \"results\": [{\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 30.4591, \"snippets\": [\"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\", \"第六条 出差期间市内交通实行包干标准:一类城市每日120元,二类城市每日100元,三类城市每日80元。\", \"| 职级 | 一类城市 | 二类城市 | 三类城市 |\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 26.4315, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"| 城市档位 | 培训住宿标准 |\", \"| 一类城市 | 500元 |\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 9.1378, \"snippets\": [\"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第二条 本办法适用于XX证券各部门、分支机构及全体员工发生的差旅、培训、招待、办公、通讯等费用报销事项。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 4.9145, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"## 第一章 总则\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 4.3943, \"snippets\": [\"## 第一章 总则\", \"第一条 为加强XX证券预算约束和费用过程控制,制定本办法。\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783412032861,"end":1783412032918}},"id":"prt_f3ba4044a001mwexqNyAv9WV4m","sessionID":"ses_0c45c28d3ffejq1z8P2CsHC8PZ","messageID":"msg_f3ba3d9ee001AOftjR562GQfmk"}}

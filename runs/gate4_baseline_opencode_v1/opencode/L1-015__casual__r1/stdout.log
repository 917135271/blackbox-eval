{"type":"tool_use","timestamp":1783413215375,"sessionID":"ses_0c44a1d98ffeJosGOikOB07ERu","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_RXx3CPbV2lgLhMlOJKUk3709","state":{"status":"completed","input":{"query":"逾期 overdue 超期","top_k":5},"output":"{\"query\": \"逾期 overdue 超期\", \"top_k\": 5, \"results\": [{\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 8.3508, \"snippets\": [\"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"第五条 培训期间住宿标准如下,单位为元/人/晚。\", \"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 7.5046, \"snippets\": [\"第九条 会计年度末发生的费用,最迟可在财政年度结束后15天内补充提交,逾期按超期报销处理。\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 6.2892, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第六条 出差期间市内交通实行包干标准:一类城市每日120元,二类城市每日100元,三类城市每日80元。\", \"第七条 培训期间住宿不适用本办法住宿表,应按《XX证券培训费管理办法》执行。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 1.9423, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 1.9247, \"snippets\": [\"第二条 业务招待单次活动费用不得超过5000元。\", \"第三条 业务招待费用按参与人数核算,人均不得超过300元。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783413215361,"end":1783413215372}},"id":"prt_f3bb60fd8001iGC15suzs3eoWr","sessionID":"ses_0c44a1d98ffeJosGOikOB07ERu","messageID":"msg_f3bb605cf0015LmG8ObyycGNDa"}}

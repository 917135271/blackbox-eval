{"type":"tool_use","timestamp":1783412951141,"sessionID":"ses_0c44e198bffeExJkvyQE1BDGwV","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_ua4cKguXcd2SsjFsyAWv4480","state":{"status":"completed","input":{"query":"OVERSTD 超标 异常","top_k":10},"output":"{\"query\": \"OVERSTD 超标 异常\", \"top_k\": 10, \"results\": [{\"doc_id\": \"11_attendance_management.md\", \"title\": \"XX证券考勤与休假管理办法\", \"score\": 4.9911, \"snippets\": [\"第一条 为规范XX证券考勤记录、请假申请、外勤登记和异常处理相关管理事项,制定本办法。\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 4.5777, \"snippets\": [\"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\", \"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 2.5397, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"## 第二章 培训费用标准\", \"第二条 培训课程费按人次控制,每人每期不超过3500元。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 2.2193, \"snippets\": [\"## 第二章 标准管理\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"第三条 业务招待费用按参与人数核算,人均不得超过300元。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 1.9952, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\", \"## 第三章 住宿标准\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 1.6882, \"snippets\": [\"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 1.3923, \"snippets\": [\"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 0.243, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}, {\"doc_id\": \"13_procurement_management.md\", \"title\": \"XX证券采购管理办法\", \"score\": 0.2426, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}, {\"doc_id\": \"16_contract_management.md\", \"title\": \"XX证券合同管理办法\", \"score\": 0.2422, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783412951109,"end":1783412951122}},"id":"prt_f3bb20748001mYJ5GMBMykKQV3","sessionID":"ses_0c44e198bffeExJkvyQE1BDGwV","messageID":"msg_f3bb201260010skcIlICBMsCne"}}

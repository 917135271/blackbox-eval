{"type":"tool_use","timestamp":1783413020529,"sessionID":"ses_0c44d1059ffeYVyRkz4BGJsn6C","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_sLKjfixZvtRgmWtD8uet8938","state":{"status":"completed","input":{"query":"超标 标准 限额 上限","top_k":10},"output":"{\"query\": \"超标 标准 限额 上限\", \"top_k\": 10, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 11.2243, \"snippets\": [\"第十二条 无专项审批时,报销金额不得超过对应制度标准的1.0倍。\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\"]}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\", \"score\": 6.4967, \"snippets\": [\"## 第二章 审批权限\", \"第一条 本办法为XX证券旧版费用报销制度文本,仅作为制度沿革留档。现行制度应以《XX证券费用报销管理办法(2025修订版)》为准。\", \"第二条 旧版制度曾规定,单笔报销金额达到8000元的,应提交部门总经理审批。\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 6.3989, \"snippets\": [\"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\"]}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\", \"score\": 5.2672, \"snippets\": [\"## 附件二 费用报销审批权限表\", \"第二条 本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。\", \"第四条 授权事项发生调整的,以最新修订版附件为准。\"]}, {\"doc_id\": \"14_hr_transfer.md\", \"title\": \"XX证券人员调动管理办法\", \"score\": 3.683, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券岗位调整、任职通知、交接确认和权限变更相关管理事项,制定本办法。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 3.2729, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"## 第二章 培训费用标准\", \"第五条 培训期间住宿标准如下,单位为元/人/晚。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 2.6734, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\", \"## 第三章 住宿标准\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 2.6687, \"snippets\": [\"## 第二章 标准管理\", \"第二条 业务招待单次活动费用不得超过5000元。\", \"第三条 业务招待费用按参与人数核算,人均不得超过300元。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 1.9423, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 0.6137, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783413020472,"end":1783413020508}},"id":"prt_f3bb315f6001ZMAL7U1GHc9K01","sessionID":"ses_0c44d1059ffeYVyRkz4BGJsn6C","messageID":"msg_f3bb30a7b0010KFw90bs11TuUl"}}

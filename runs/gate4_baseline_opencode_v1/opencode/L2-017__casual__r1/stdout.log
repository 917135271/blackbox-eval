{"type":"tool_use","timestamp":1783415742487,"sessionID":"ses_0c4238b80ffeVDlsCr1WdV3ERE","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_kRYwmCOs3Giz93LS8DRO6308","state":{"status":"completed","input":{"query":"预算 超预算 报销 部门预算","top_k":5},"output":"{\"query\": \"预算 超预算 报销 部门预算\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 26.7791, \"snippets\": [\"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第二条 各部门应在年度预算额度内发生费用。\", \"第四条 因监管要求、客户服务或经营连续性确需超预算支出的,应履行专项审批。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 18.7246, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第十条 同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 8.9175, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"第四条 同一客户拜访或同一会议安排不得拆分为多个报销事项。\", \"第五条 本办法由财务部门负责解释。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 2.2189, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 2.1996, \"snippets\": [\"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"第三条 内部培训综合费用每日不超过800元。\", \"第四条 外部培训综合费用每日不超过1200元。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783415742454,"end":1783415742475}},"id":"prt_f3bdc9efc001bZ4rtZvFgmPOpC","sessionID":"ses_0c4238b80ffeVDlsCr1WdV3ERE","messageID":"msg_f3bdc95300014R8SPzR6qaC0kv"}}

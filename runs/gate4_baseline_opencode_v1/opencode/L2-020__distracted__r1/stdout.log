 \"E0034\", \"employee_name\": \"黄萍\", \"department_id\": \"D005\", \"department_name\": \"机构业务部\", \"expense_date\": \"2025-02-12\", \"reimburse_date\": \"2025-02-19\", \"expense_type\": \"travel_lodging\", \"amount\": 840.43, \"reason\": \"监管沟通事项赴杭州住宿费\", \"invoice_no\": \"FP202500002756\", \"status\": \"approved\"}]}","metadata":{"truncated":false},"title":"","time":{"start":1783416227678,"end":1783416227685}},"id":"prt_f3be406ae001KNALCxLHqAMNVK","sessionID":"ses_0c41c48c3ffe4GT2SSHlc5xvej","messageID":"msg_f3be3f84d001tRHsGFl2LMGlAm"}}

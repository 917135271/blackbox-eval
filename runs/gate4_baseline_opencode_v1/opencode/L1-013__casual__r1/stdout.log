{"type":"tool_use","timestamp":1783412988989,"sessionID":"ses_0c44daa3affe1rHm8tC7WF2aOc","part":{"type":"tool","tool":"policy_query_get_policy_excerpt","callID":"call_02_hw3GNcviPAY1IM5jsnWC7186","state":{"status":"completed","input":{"doc_id":"05_training_expense.md","query":"培训费标准 限额 每人","max_chars":2000},"output":"{\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"query\": \"培训费标准 限额 每人\", \"excerpts\": [\"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"## 第二章 培训费用标准\", \"第五条 培训期间住宿标准如下,单位为元/人/晚。\", \"第三条 内部培训综合费用每日不超过800元。\"]}","metadata":{"truncated":false},"title":"","time":{"start":1783412988923,"end":1783412988934}},"id":"prt_f3bb29a9e001n7kGpK7gar4o9v","sessionID":"ses_0c44daa3affe1rHm8tC7WF2aOc","messageID":"msg_f3bb288600019p45fFZ4rq13z0"}}

loyee_name\": \"莫佳\", \"department_id\": \"D007\", \"department_name\": \"信息技术部\", \"expense_date\": \"2025-01-04\", \"reimburse_date\": \"2025-02-13\", \"expense_type\": \"office_supplies\", \"amount\": 301.04, \"reason\": \"信息技术部硒鼓和纸张费用\", \"invoice_no\": \"FP202500002745\", \"status\": \"approved\"}, {\"record_id\": \"R002867\", \"record_no\": \"BX2025002867\", \"employee_id\": \"E0056\", \"employee_name\": \"李想\", \"department_id\": \"D005\", \"department_name\": \"机构业务部\", \"expense_date\": \"2025-01-04\", \"reimburse_date\": \"2025-01-19\", \"expense_type\": \"training_fee\", \"amount\": 1482.43, \"reason\": \"星河专项知识培训费\", \"invoice_no\": \"FP202500002867\", \"status\": \"approved\"}, {\"record_id\": \"R002888\", \"record_no\": \"BX2025002888\", \"employee_id\": \"E0060\", \"employee_name\": \"金金凤\", \"department_id\": \"D006\", \"department_name\": \"运营管理部\", \"expense_date\": \"2025-01-04\", \"reimburse_date\": \"2025-03-04\", \"expense_type\": \"travel_lodging\", \"amount\": 1049.48, \"reason\": \"启明现场审阅底稿住宿费\", \"invoice_no\": \"FP202500002888\", \"status\": \"approved\"}, {\"record_id\": \"R003139\", \"record_no\": \"BX2025003139\", \"employee_id\": \"E0042\", \"employee_name\": \"谢玉\", \"department_id\": \"D008\", \"department_name\": \"合规风控部\", \"expense_date\": \"2025-01-04\", \"reimburse_date\": \"2025-01-31\", \"expense_type\": \"office_supplies\", \"amount\": 474.31, \"reason\": \"合规风控部硒鼓和纸张费用\", \"invoice_no\": \"FP202500003139\", \"status\": \"approved\"}, {\"record_id\": \"R000020\", \"record_no\": \"BX2025000020\", \"employee_id\": \"E0028\", \"employee_name\": \"杜丹\", \"department_id\": \"D009\", \"department_name\": \"财务管理部\", \"expense_date\": \"2025-01-05\", \"reimburse_date\": \"2025-02-28\", \"expense_type\": \"travel_lodging\", \"amount\": 669.5, \"reason\": \"财务管理部跨部门协同赴杭州住宿费\", \"invoice_no\": \"FP202500000020\", \"status\": \"approved\"}, {\"record_id\": \"R000777\", \"record_no\": \"BX2025000777\", \"employee_id\": \"E0034\", \"employ
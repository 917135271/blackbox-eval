022\", \"employee_name\": \"刘冬梅\", \"department_id\": \"D007\", \"department_name\": \"信息技术部\", \"expense_date\": \"2025-02-24\", \"reimburse_date\": \"2025-02-25\", \"expense_type\": \"business_entertainment\", \"amount\": 1030.04, \"reason\": \"启明投后沟通招待费\", \"invoice_no\": \"FP202500001297\", \"status\": \"approved\"}]}","metadata":{"truncated":false},"title":"","time":{"start":1783416347646,"end":1783416347652}},"id":"prt_f3be5db8e001oMUPnvdneeHmjn","sessionID":"ses_0c41a570effeQ6gbk9QGOB0eDw","messageID":"msg_f3be5cba2001TdMX7oNehvkpMB"}}

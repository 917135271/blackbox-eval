235\", \"employee_id\": \"E0053\", \"employee_name\": \"姜燕\", \"department_id\": \"D010\", \"department_name\": \"人力资源部\", \"expense_date\": \"2025-04-02\", \"reimburse_date\": \"2025-05-08\", \"expense_type\": \"training_fee\", \"amount\": 3044.3, \"reason\": \"数据治理线上课程学习费\", \"invoice_no\": \"FP202500002235\", \"status\": \"approved\"}]}","metadata":{"truncated":false},"title":"","time":{"start":1783415334557,"end":1783415334574}},"id":"prt_f3bd665fe001kD63CA6SdDr7hO","sessionID":"ses_0c429d647ffeWMMuLPcoSIT0cP","messageID":"msg_f3bd65ec00011uJfQne0WrjlXM"}}

{"type":"tool_use","timestamp":1783414847380,"sessionID":"ses_0c4312564ffeqKZBmuXoPJuP7u","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_kiSg5xugsCH6Uy0Xk3B66389","state":{"status":"completed","input":{"query":"信息技术部 超标准 费用报销","top_k":5},"output":"{\"query\": \"信息技术部 超标准 费用报销\", \"top_k\": 5, \"results\": [{\"doc_id\": \"18_it_asset.md\", \"title\": \"XX证券信息技术资产管理办法\", \"score\": 10.2662, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"# XX证券信息技术资产管理办法\", \"第二条 本办法适用于XX证券总部、分支机构及相关工作人员。\"]}, {\"doc_id\": \"09_information_security.md\", \"title\": \"XX证券信息安全管理办法\", \"score\": 4.9624, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"# XX证券信息安全管理办法\", \"第二条 本办法适用于XX证券总部、分支机构及相关工作人员。\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 3.0348, \"snippets\": [\"第六条 培训住宿标准仅适用于培训期间住宿,不得与差旅住宿标准混用。\", \"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"## 第二章 培训费用标准\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 2.735, \"snippets\": [\"第二条 业务招待单次活动费用不得超过5000元。\", \"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"## 第二章 标准管理\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 2.5693, \"snippets\": [\"第五条 超过住宿标准且无专项审批的,不得报销超出部分。\", \"第二条 差旅费包括城市间交通费、住宿费、市内交通包干等与公务出差直接相关的费用。\", \"第三条 住宿标准按员工职级和城市档位确定。员工职级包括员工级、经理级、部门负责人级和高管级;城市档位包括一类城市、二类城市和三类城市。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783414847312,"end":1783414847362}},"id":"prt_f3bcef6280018p8LSDBArHcaZL","sessionID":"ses_0c4312564ffeqKZBmuXoPJuP7u","messageID":"msg_f3bceeced001n3eY2t7slZrWyI"}}

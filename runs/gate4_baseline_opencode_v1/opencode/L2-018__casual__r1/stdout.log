\"E0066\", \"employee_name\": \"何楠\", \"department_id\": \"D003\", \"department_name\": \"财富管理部\", \"expense_date\": \"2025-12-24\", \"reimburse_date\": \"2026-01-07\", \"expense_type\": \"office_supplies\", \"amount\": 195.69, \"reason\": \"北辰现场办公用品费\", \"invoice_no\": \"FP202500003544\", \"status\": \"approved\"}, {\"record_id\": \"R001049\", \"record_no\": \"BX2025001049\", \"employee_id\": \"E0066\", \"employee_name\": \"何楠\", \"department_id\": \"D003\", \"department_name\": \"财富管理部\", \"expense_date\": \"2025-12-30\", \"reimburse_date\": \"2026-01-14\", \"expense_type\": \"travel_lodging\", \"amount\": 1638.88, \"reason\": \"赴上海开展系统上线支持住宿费\", \"invoice_no\": \"FP202500001049\", \"status\": \"approved\"}]}","metadata":{"truncated":false},"title":"","time":{"start":1783415856028,"end":1783415856036}},"id":"prt_f3bde5ae0001Td7p3ltFPXkwmm","sessionID":"ses_0c421cb95ffeNOrpqWWqKmjN0A","messageID":"msg_f3bde4f2b0016Lbq58WzvdwIjE"}}

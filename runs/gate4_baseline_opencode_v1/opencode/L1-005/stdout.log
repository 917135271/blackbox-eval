{"type":"tool_use","timestamp":1783412071004,"sessionID":"ses_0c45b7e1fffeK1S5xxq0tqY3pM","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_bJy8fYVA8jUVnrhcgPvS1993","state":{"status":"completed","input":{"query":"培训课程费 每人 每期 上限","top_k":10},"output":"{\"query\": \"培训课程费 每人 每期 上限\", \"top_k\": 10, \"results\": [{\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 21.6105, \"snippets\": [\"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"第三条 内部培训综合费用每日不超过800元。\"]}, {\"doc_id\": \"04_travel_expense.md\", \"title\": \"XX证券差旅费管理办法\", \"score\": 13.0643, \"snippets\": [\"第六条 出差期间市内交通实行包干标准:一类城市每日120元,二类城市每日100元,三类城市每日80元。\", \"第七条 培训期间住宿不适用本办法住宿表,应按《XX证券培训费管理办法》执行。\", \"第二条 差旅费包括城市间交通费、住宿费、市内交通包干等与公务出差直接相关的费用。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 9.6549, \"snippets\": [\"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第二条 本办法适用于XX证券各部门、分支机构及全体员工发生的差旅、培训、招待、办公、通讯等费用报销事项。\", \"第三条 费用报销实行经办人真实性承诺、部门负责人业务审核、财务复核和授权审批相结合的管理原则。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 7.5345, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"第四条 办公费用和通讯费用不得以其他费用类型绕开月度控制。\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 2.8623, \"snippets\": [\"第一条 为加强XX证券预算约束和费用过程控制,制定本办法。\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第五条 本办法与费用报销制度共同构成费用控制依据。\"]}, {\"doc_id\": \"14_hr_transfer.md\", \"title\": \"XX证券人员调动管理办法\", \"score\": 2.2368, \"snippets\": [\"# XX证券人员调动管理办法\", \"第一条 为规范XX证券岗位调整、任职通知、交接确认和权限变更相关管理事项,制定本办法。\", \"第二条 本办法适用于XX证券总部、分支机构及相关工作人员。\"]}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\", \"score\": 1.8288, \"snippets\": [\"第一条 本办法为XX证券旧版费用报销制度文本,仅作为制度沿革留档。现行制度应以《XX证券费用报销管理办法(2025修订版)》为准。\", \"# XX证券费用报销管理办法(2022版)\", \"## 第二章 审批权限\"]}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\", \"score\": 1.7628, \"snippets\": [\"## 附件二 费用报销审批权限表\", \"第二条 本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。\", \"第三条 各部门应按系统派生结果提交审批,不得以口头授权替代系统流程。\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 0.6758, \"snippets\": [\"第二条 本办法适用于XX证券总部、分支机构及相关工作人员。\", \"第三条 牵头部门负责制度解释、流程维护和监督检查。\", \"第四条 各部门应结合岗位职责落实过程管理要求,形成完整、真实、可追溯的管理记录。\"]}, {\"doc_id\": \"13_procurement_management.md\", \"title\": \"XX证券采购管理办法\", \"score\": 0.6751, \"snippets\": [\"第二条 本办法适用于XX证券总部、分支机构及相关工作人员。\", \"第三条 牵头部门负责制度解释、流程维护和监督检查。\", \"第四条 各部门应结合岗位职责落实过程管理要求,形成完整、真实、可追溯的管理记录。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783412070886,"end":1783412070917}},"id":"prt_f3ba498ee001g5fNbLcJJZcdYx","sessionID":"ses_0c45b7e1fffeK1S5xxq0tqY3pM","messageID":"msg_f3ba484b800186myNULkvm30rz"}}

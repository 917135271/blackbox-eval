{"type":"tool_use","timestamp":1783412770262,"sessionID":"ses_0c450e4b7ffeoG9W0aFI2raytv","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_OzJyCX2kK0L9pwFgP47A5935","state":{"status":"completed","input":{"query":"DUP 重复报销 异常编号","top_k":10},"output":"{\"query\": \"DUP 重复报销 异常编号\", \"top_k\": 10, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 6.3821, \"snippets\": [\"第十条 同一发票最多报销1次。发现同一发票在不同报销单中重复出现的,应认定为重复报销风险。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\", \"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\"]}, {\"doc_id\": \"11_attendance_management.md\", \"title\": \"XX证券考勤与休假管理办法\", \"score\": 4.9328, \"snippets\": [\"发文字号: XX证综规〔2025〕备号\", \"第一条 为规范XX证券考勤记录、请假申请、外勤登记和异常处理相关管理事项,制定本办法。\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 2.9519, \"snippets\": [\"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\", \"发文字号: XX证办规〔2025〕庚号\", \"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\"]}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\", \"score\": 1.9799, \"snippets\": [\"发文字号: XX证综规〔2025〕丙号\", \"第二条 本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。\", \"## 附件二 费用报销审批权限表\"]}, {\"doc_id\": \"20_customer_complaint.md\", \"title\": \"XX证券客户投诉处理管理办法\", \"score\": 1.9645, \"snippets\": [\"发文字号: XX证综规〔2025〕备号\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券投诉受理、事实核查、回复留痕和改进闭环相关管理事项,制定本办法。\"]}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\", \"score\": 0.3391, \"snippets\": [\"第一条 本办法为XX证券旧版费用报销制度文本,仅作为制度沿革留档。现行制度应以《XX证券费用报销管理办法(2025修订版)》为准。\", \"# XX证券费用报销管理办法(2022版)\", \"发文字号: XX证财规〔2022〕乙号\"]}, {\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 0.2774, \"snippets\": [\"发文字号: XX证财规〔2025〕辛号\", \"第三条 部门费用累计使用达到年度预算额度的1.0倍后,原则上不得继续报销。\", \"第五条 本办法与费用报销制度共同构成费用控制依据。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 0.2206, \"snippets\": [\"发文字号: XX证客规〔2025〕己号\", \"第四条 同一客户拜访或同一会议安排不得拆分为多个报销事项。\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 0.2157, \"snippets\": [\"发文字号: XX证综规〔2025〕备号\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券档案归集、借阅、保管、移交和销毁相关管理事项,制定本办法。\"]}, {\"doc_id\": \"09_information_security.md\", \"title\": \"XX证券信息安全管理办法\", \"score\": 0.1881, \"snippets\": [\"发文字号: XX证综规〔2025〕备号\", \"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"第一条 为规范XX证券系统账号、数据访问、终端安全和日志留存相关管理事项,制定本办法。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783412770205,"end":1783412770229}},"id":"prt_f3baf454f0013TtDu7R01fGaXU","sessionID":"ses_0c450e4b7ffeoG9W0aFI2raytv","messageID":"msg_f3baf37e9001smIbFnvw3KBuyP"}}

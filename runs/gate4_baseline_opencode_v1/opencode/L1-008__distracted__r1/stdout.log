{"type":"tool_use","timestamp":1783412492876,"sessionID":"ses_0c4557105ffeqBHo0cbN3684Fi","part":{"type":"tool","tool":"policy_query_get_policy_excerpt","callID":"call_01_H5uMSajaGCCdKmSXPFfD9080","state":{"status":"completed","input":{"doc_id":"07_office_communication.md","query":"办公用品月度标准限额 每人每月","max_chars":800},"output":"{\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"query\": \"办公用品月度标准限额 每人每月\", \"excerpts\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"第四条 办公费用和通讯费用不得以其他费用类型绕开月度控制。\", \"第一条 为规范XX证券日常办公费用和通讯费用报销,制定本办法。\", \"# XX证券办公与通讯费用管理办法\", \"## 第二章 办公费用\"]}","metadata":{"truncated":false},"title":"","time":{"start":1783412492841,"end":1783412492854}},"id":"prt_f3bab08f6001PpPPZaqO0OBrA5","sessionID":"ses_0c4557105ffeqBHo0cbN3684Fi","messageID":"msg_f3baae0c1001lAZLQj7BawAjxV"}}

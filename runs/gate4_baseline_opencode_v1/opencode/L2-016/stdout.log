{"type":"tool_use","timestamp":1783415528193,"sessionID":"ses_0c426cb6fffesl2A5LTvGzYyic","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_wFiBruKkBc3E0FZPzuyk3437","state":{"status":"completed","input":{"query":"超预算 预算超额 预算管理办法 超过年度预算 预算控制","top_k":5},"output":"{\"query\": \"超预算 预算超额 预算管理办法 超过年度预算 预算控制\", \"top_k\": 5, \"results\": [{\"doc_id\": \"08_budget_management.md\", \"title\": \"XX证券预算管理办法\", \"score\": 54.6474, \"snippets\": [\"第一条 为加强XX证券预算约束和费用过程控制,制定本办法。\", \"# XX证券预算管理办法\", \"第二条 各部门应在年度预算额度内发生费用。\"]}, {\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 37.5697, \"snippets\": [\"第十三条 部门年度预算不足时不得继续报销。预算使用达到预算额度的1.0倍后,确需发生的费用应履行专项审批。\", \"第六条 财务部门对票据合法性、费用归属、预算占用和制度标准进行复核。复核不替代业务部门对事项真实性的确认。\", \"第九条 会计年度末发生的费用,最迟可在财政年度结束后15天内补充提交,逾期按超期报销处理。\"]}, {\"doc_id\": \"06_business_entertainment.md\", \"title\": \"XX证券业务招待费管理办法\", \"score\": 17.1239, \"snippets\": [\"第三条 业务招待费用按参与人数核算,人均不得超过300元。\", \"# XX证券业务招待费管理办法\", \"第二条 业务招待单次活动费用不得超过5000元。\"]}, {\"doc_id\": \"07_office_communication.md\", \"title\": \"XX证券办公与通讯费用管理办法\", \"score\": 9.8803, \"snippets\": [\"第二条 员工个人办公用品报销按月控制,每人每月不超过600元。\", \"第三条 员工通讯费用报销按月控制,每人每月不超过300元。\", \"# XX证券办公与通讯费用管理办法\"]}, {\"doc_id\": \"05_training_expense.md\", \"title\": \"XX证券培训费管理办法\", \"score\": 8.5665, \"snippets\": [\"第二条 培训课程费按人次控制,每人每期不超过3500元。\", \"第一条 为加强XX证券培训经费管理,规范内部培训和外部培训费用支出,制定本办法。\", \"# XX证券培训费管理办法\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783415528148,"end":1783415528171}},"id":"prt_f3bd9598000147E64h9B6zuQot","sessionID":"ses_0c426cb6fffesl2A5LTvGzYyic","messageID":"msg_f3bd953ed001E2AT5xjGHzNIxE"}}

{"type":"tool_use","timestamp":1783411873666,"sessionID":"ses_0c45e82a0ffeFpW6vGQKXqDXGf","part":{"type":"tool","tool":"policy_query_search_policy","callID":"call_00_PowWMN4POs17eL5TwnZf3908","state":{"status":"completed","input":{"query":"费用报销 提交时限 天数","top_k":5},"output":"{\"query\": \"费用报销 提交时限 天数\", \"top_k\": 5, \"results\": [{\"doc_id\": \"01_expense_reimbursement_2025.md\", \"title\": \"XX证券费用报销管理办法(2025修订版)\", \"score\": 7.3843, \"snippets\": [\"第七条 员工应在费用发生后60天内提交报销申请;超过期限的,原则上不得报销。\", \"第十一条 不得将同一事项或同类事项拆分为多笔报销以规避审批权限。同一员工、同一费用类型在7天内出现2笔及以上报销,且合计金额达到《授权管理办法》附件二较高审批线的,应重点核查拆分规\", \"第五条 单笔费用报销的审批权限,不在本办法正文列示具体金额,统一按《XX证券授权管理办法》附件二执行。费用系统应按附件二自动派生审批角色。\"]}, {\"doc_id\": \"02_expense_reimbursement_2022_deprecated.md\", \"title\": \"XX证券费用报销管理办法(2022版)\", \"score\": 2.7288, \"snippets\": [\"第一条 本办法为XX证券旧版费用报销制度文本,仅作为制度沿革留档。现行制度应以《XX证券费用报销管理办法(2025修订版)》为准。\", \"# XX证券费用报销管理办法(2022版)\", \"第二条 旧版制度曾规定,单笔报销金额达到8000元的,应提交部门总经理审批。\"]}, {\"doc_id\": \"14_hr_transfer.md\", \"title\": \"XX证券人员调动管理办法\", \"score\": 2.5579, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\", \"第一条 为规范XX证券岗位调整、任职通知、交接确认和权限变更相关管理事项,制定本办法。\"]}, {\"doc_id\": \"03_authorization_management.md\", \"title\": \"XX证券授权管理办法\", \"score\": 2.261, \"snippets\": [\"第二条 本办法附件二适用于费用报销系统自动派生审批角色,相关金额为现行有效审批线。\", \"## 附件二 费用报销审批权限表\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\"]}, {\"doc_id\": \"12_archive_management.md\", \"title\": \"XX证券档案管理办法\", \"score\": 1.0616, \"snippets\": [\"第八条 本办法为管理类制度,不作为费用报销标准依据。\", \"<!-- SYNTHETIC TEST FIXTURE — 虚构测试数据,禁止用于交付 -->\", \"第一条 为规范XX证券档案归集、借阅、保管、移交和销毁相关管理事项,制定本办法。\"]}]}","metadata":{"truncated":false},"title":"","time":{"start":1783411873535,"end":1783411873580}},"id":"prt_f3ba1962d001NNUHeQKBnAzaqW","sessionID":"ses_0c45e82a0ffeFpW6vGQKXqDXGf","messageID":"msg_f3ba18087001bMKToQ2YC2H2ed"}}

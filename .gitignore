# Candidate runtime installs are large and reproducible from setup.md.
candidates/goose/install/
candidates/claude-code/vendor/
candidates/claude-code/runtime/
candidates/claude-code/config/
candidates/trae-agent/vendor/
candidates/openclaude/vendor/
candidates/openclaude/runtime/
candidates/openclaude/config/
candidates/opencode/vendor/
candidates/opencode/runtime/
candidates/codex/vendor/
candidates/codex/build-cache/
candidates/codex/source-artifacts/codex
candidates/codex/runtime*/
candidates/codex/.tmp/
candidates/codex/tmp/
candidates/codex/config/
candidates/codex/sessions/
candidates/codex/skills/
candidates/codex/*.sqlite*
candidates/codex/installation_id
candidates/pi-agent-build/

# Local dependency and build caches.
**/.venv/
**/node_modules/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
*.py[cod]
grades_*_smoke.jsonl
runs/**/grades_*_smoke.jsonl
runs/_process_logs/
runs/_retry_replaced/
runs/gate2_domain_enhancement_attempt*/
runs/gate3_development_attempt*/
runs/gate3_development-stale-*/
runs/gate3_scripted-stale-*/
runs/gate4_formal-stale-*/
runs/gate4_scripted-stale-*/
runs/gate4_retry_*/
runs/gate4_standard_codex_v4pro_v1/
runs/gate4_standard_trae_v4pro_v1/
runs/gate3_smoke_*/
runs/gate3_contract_smoke_*/
output/tmp_codex_home_probe/

# Per-run framework state and interrupted-process files are reproducible noise.
runs/**/codex-home/
runs/**/proxy/
runs/**/retry-history/
runs/**/active_runner.json
# Some frameworks emit cumulative model transcripts that can exceed hundreds
# of MB per task. Structured events, tool calls, artifacts, and grades remain.
runs/**/artifacts/trajectory.jsonl
runs/**/artifacts/latest
runs/**/*.sqlite-wal
runs/**/*.sqlite-shm
runs/**/*.db-wal
runs/**/*.db-shm
output/*.stdout.log
output/*.stderr.log

# Local environment/secrets. Benchmark config must reference env vars only.
.env
.env.*
*.pem
*.key

# OS/editor noise.
.DS_Store
Thumbs.db
*.swp
*.tmp

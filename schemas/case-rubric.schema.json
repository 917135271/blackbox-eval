{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/case-rubric.schema.json",
  "title": "Securities expense audit case-by-case rubric dataset",
  "type": "object",
  "required": ["dataset_id", "rubric_version", "case_count", "source", "cases"],
  "additionalProperties": false,
  "properties": {
    "dataset_id": {"type": "string", "minLength": 1},
    "rubric_version": {"const": "atomic-binary-checklist-v5"},
    "case_count": {"const": 15},
    "source": {
      "type": "object",
      "required": ["evals", "ground_truth"],
      "additionalProperties": false,
      "properties": {
        "evals": {"type": "string"},
        "ground_truth": {"type": "string"}
      }
    },
    "case_family_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 1}
    },
    "cases": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": [
        "id",
        "source_task_id",
        "level",
        "category",
        "case_family",
        "prompt",
        "selection_reason",
        "ground_truth_refs",
        "expected_output",
        "rubric"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
        "source_task_id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
        "level": {"enum": ["L1", "L2", "L3", "trap"]},
        "category": {"type": "string", "minLength": 1},
        "case_family": {
          "enum": [
            "policy_and_version",
            "record_audit",
            "full_year_audit",
            "clean_trap",
            "retrieval_and_report"
          ]
        },
        "prompt": {"type": "string", "minLength": 1},
        "source_prompt": {"type": "string", "minLength": 1},
        "prompt_change_reason": {"type": "string", "minLength": 1},
        "selection_reason": {"type": "string", "minLength": 1},
        "ground_truth_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expected_output": {"type": "object"},
        "rubric": {"$ref": "#/$defs/rubric"}
      }
    },
    "rubric": {
      "type": "object",
      "required": [
        "scoring_method",
        "item_result_values",
        "normalization",
        "checklist"
      ],
      "additionalProperties": false,
      "properties": {
        "scoring_method": {"const": "binary_checklist"},
        "normalization": {"const": "equal_item_ratio"},
        "item_result_values": {
          "type": "array",
          "prefixItems": [{"const": 0}, {"const": 1}],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "checklist": {
          "type": "array",
          "minItems": 4,
          "items": {"$ref": "#/$defs/checkItem"}
        }
      }
    },
    "checkItem": {
      "type": "object",
      "required": [
        "id",
        "check",
        "metric",
        "evaluation_mode",
        "expected",
        "evidence_sources",
        "pass_condition",
        "fail_condition"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "check": {"type": "string", "minLength": 1},
        "metric": {
          "enum": ["conclusion", "evidence", "policy", "reasoning", "false_positive", "format"]
        },
        "evaluation_mode": {"enum": ["deterministic", "llm", "hybrid"]},
        "deterministic_rule": {
          "enum": [
            "expected-record-present",
            "no-unexpected-records",
            "anomaly-rule-type-exact",
            "anomaly-count-exact",
            "anomaly-type-count-exact",
            "no-anomaly-ids",
            "record-ids-unique"
          ]
        },
        "expected": {},
        "evidence_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["final_answer", "submitted_json", "tool_trace", "workspace_artifact"]}
        },
        "pass_condition": {"type": "string", "minLength": 1},
        "fail_condition": {"type": "string", "minLength": 1}
      }
    }
  }
}

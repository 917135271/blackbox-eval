{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/case-rubric.schema.json",
  "title": "Securities expense audit case-by-case rubric dataset",
  "type": "object",
  "required": ["dataset_id", "case_count", "source", "cases"],
  "additionalProperties": false,
  "properties": {
    "dataset_id": {"type": "string", "minLength": 1},
    "case_count": {"const": 15},
    "source": {
      "type": "object",
      "required": ["evals", "ground_truth"],
      "additionalProperties": false,
      "properties": {
        "evals": {"type": "string"},
        "ground_truth": {"type": "string"}
      }
    },
    "case_family_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 1}
    },
    "cases": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": [
        "id",
        "source_task_id",
        "level",
        "category",
        "case_family",
        "prompt",
        "selection_reason",
        "ground_truth_refs",
        "expected_output",
        "rubric"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
        "source_task_id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
        "level": {"enum": ["L1", "L2", "L3", "trap"]},
        "category": {"type": "string", "minLength": 1},
        "case_family": {
          "enum": [
            "policy_and_version",
            "record_audit",
            "full_year_audit",
            "clean_trap",
            "retrieval_and_report"
          ]
        },
        "prompt": {"type": "string", "minLength": 1},
        "selection_reason": {"type": "string", "minLength": 1},
        "ground_truth_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expected_output": {"type": "object"},
        "rubric": {"$ref": "#/$defs/rubric"}
      }
    },
    "rubric": {
      "type": "object",
      "required": ["max_score", "pass_score", "criteria", "critical_failures"],
      "additionalProperties": false,
      "properties": {
        "max_score": {"const": 100},
        "pass_score": {"type": "integer", "minimum": 1, "maximum": 100},
        "criteria": {
          "type": "array",
          "minItems": 4,
          "items": {"$ref": "#/$defs/criterion"}
        },
        "critical_failures": {
          "type": "array",
          "items": {"$ref": "#/$defs/criticalFailure"}
        }
      }
    },
    "criterion": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "weight",
        "metric",
        "evaluation_mode",
        "expected",
        "evidence_sources",
        "anchors"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "weight": {"type": "integer", "minimum": 1, "maximum": 100},
        "metric": {
          "enum": ["conclusion", "evidence", "policy", "reasoning", "false_positive", "format"]
        },
        "evaluation_mode": {"enum": ["deterministic", "llm", "hybrid"]},
        "expected": {},
        "evidence_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["final_answer", "submitted_json", "tool_trace", "workspace_artifact"]}
        },
        "anchors": {
          "type": "object",
          "required": ["full", "partial", "zero"],
          "additionalProperties": false,
          "properties": {
            "full": {"type": "string", "minLength": 1},
            "partial": {"type": "string", "minLength": 1},
            "zero": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "criticalFailure": {
      "type": "object",
      "required": ["id", "condition", "score_cap"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "condition": {"type": "string", "minLength": 1},
        "score_cap": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    }
  }
}
